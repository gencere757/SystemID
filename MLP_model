clc;clear;close all;
load("features.mat");
load("data.mat");

%% Make input and output regressors
maxLag = max([significant_input_lags(:); top_output_lags(:)]);

N = length(y);

X = zeros(N-maxLag, length(top_output_lags)+length(significant_input_lags));
Y = zeros(N-maxLag,1);

for k = maxLag+1:N

    % Output regressors
    yReg = y(k-top_output_lags);

    % Input regressors
    uReg = u(k-significant_input_lags);

    X(k-maxLag,:) = [yReg(:)' uReg(:)'];
    Y(k-maxLag) = y(k);

end

%% Split data for validation (first 70% for training, last 30% for testing)
total_samples = size(X,1);
random = randperm(total_samples);
train_ratio = 0.7;
train_amount = total_samples*train_ratio;


train_idx = random(1:train_amount);
val_idx = random(train_amount+1:end);

XTrain = X(train_idx,:);
YTrain = Y(train_idx);
XVal = X(val_idx,:);
YVal = Y(val_idx);

%% Normalize the data
[XTrain,muX,sigmaX] = zscore(XTrain);

XVal = (XVal-muX)./sigmaX;

[YTrain,muY,sigmaY] = zscore(YTrain);

YVal = (YVal-muY)./sigmaY;

%% Architecture
numFeatures = size(XTrain,2);

layers = [

    featureInputLayer(numFeatures,"Normalization","none")

    fullyConnectedLayer(128)
    reluLayer

    fullyConnectedLayer(64)
    reluLayer

    fullyConnectedLayer(32)
    reluLayer

    fullyConnectedLayer(1)

    regressionLayer

];

options = trainingOptions("adam",...
    MaxEpochs=50,...
    MiniBatchSize=256,...
    InitialLearnRate=1e-3,...
    Shuffle="every-epoch",...
    ValidationData={XVal,YVal},...
    Plots="training-progress",...
    Verbose=false);
%% Train
net = trainNetwork(XTrain,YTrain,layers,options);

%% Prediction
YPred = predict(net,XVal);

% Undo normalization
YPred = YPred*sigmaY + muY;
YTrue = YVal*sigmaY + muY;
%% Calculate error
rmse = sqrt(mean((YTrue-YPred).^2));

fit = 100*(1-norm(YTrue-YPred)/norm(YTrue-mean(YTrue)));

figure;
plot(YTrue);
hold on;
plot(YPred);
legend('True','Prediction');
